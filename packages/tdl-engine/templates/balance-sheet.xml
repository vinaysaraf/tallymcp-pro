<?xml version="1.0" encoding="utf-8"?>
<ENVELOPE>
  <HEADER>
    <VERSION>1</VERSION>
    <TALLYREQUEST>Export</TALLYREQUEST>
    <TYPE>Data</TYPE>
    <ID>TallyMcpTdlReport</ID>
  </HEADER>
  <BODY>
    <DESC>
      <STATICVARIABLES>
        <SVEXPORTFORMAT>$$SysName:XML</SVEXPORTFORMAT>
        <SVFROMDATE>{fromDate}</SVFROMDATE>
        <SVTODATE>{toDate}</SVTODATE>
        <nunjuck>if targetCompany</nunjuck>
        <SVCURRENTCOMPANY>{{targetCompany | escape}}</SVCURRENTCOMPANY>
        <nunjuck>endif</nunjuck>
      </STATICVARIABLES>
      <TDL>
        <TDLMESSAGE>
          <REPORT NAME="TallyMcpTdlReport"><FORMS>TallyMcpForm</FORMS></REPORT>
          <FORM NAME="TallyMcpForm"><PARTS>TallyMcpPart</PARTS><XMLTAG>DATA</XMLTAG></FORM>
          <PART NAME="TallyMcpPart"><LINES>TallyMcpLine</LINES><REPEAT>TallyMcpLine : TallyMcpCollection</REPEAT><SCROLLED>Vertical</SCROLLED></PART>
          <LINE NAME="TallyMcpLine"><FIELDS>Fld01,Fld02,Fld03</FIELDS><XMLTAG>ROW</XMLTAG></LINE>
          <FIELD NAME="Fld01"><SET>$Name</SET><XMLTAG>F01</XMLTAG></FIELD>
          <FIELD NAME="Fld02"><SET>if $$IsEqual:$Parent:$$SysName:Primary then "" else $Parent</SET><XMLTAG>F02</XMLTAG></FIELD>
          <FIELD NAME="Fld03"><SET>if $$IsEmpty:$ClosingBalance then 0 else $$StringFindAndReplace:(if $$IsDebit:$ClosingBalance then -$$Number:$ClosingBalance else $$Number:$ClosingBalance):"(-)":"-"</SET><XMLTAG>F03</XMLTAG></FIELD>
          <COLLECTION NAME="TallyMcpCollection">
            <TYPE>Group</TYPE>
            <FILTER>IsBSGrp</FILTER>
          </COLLECTION>
          <SYSTEM TYPE="Formulae" NAME="IsBSGrp">NOT $IsRevenue</SYSTEM>
        </TDLMESSAGE>
      </TDL>
    </DESC>
  </BODY>
</ENVELOPE>
